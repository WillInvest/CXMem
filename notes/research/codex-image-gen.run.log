+|---|---:|---:|---:|---:|---:|---:|
+| `gpt-image-2` | $5.00 | $1.25 | n/a | $8.00 | $2.00 | $30.00 |
+| `gpt-image-1.5` | $5.00 | $1.25 | $10.00 | $8.00 | $2.00 | $32.00 |
+| `gpt-image-1-mini` | $2.00 | $0.20 | n/a | $2.50 | $0.25 | $8.00 |
